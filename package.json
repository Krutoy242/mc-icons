{
  "name": "mc-icons",
  "type": "module",
  "version": "1.9.1",
  "packageManager": "pnpm@11.5.0",
  "description": "Parsing markdown file to replace item names into item icons.",
  "license": "MIT",
  "repository": "https://github.com/Krutoy242/E2E-E-icons",
  "keywords": [],
  "main": "./build/index.js",
  "bin": "./build/cli.js",
  "files": [
    "README.md",
    "assets",
    "build"
  ],
  "engines": {
    "node": ">=14.16"
  },
  "scripts": {
    "add-new-images": "git add -fv i",
    "release": "tsc && release-it",
    "test": "vitest run",
    "test run": "tsx src/cli.ts README.md --no-short --repo=i/",
    "preparse": "tsx src/tool/preparse.ts --mc=D:/mc_client/Instances/E2E-E --icons=icon-exports-x64 --modpack=e2ee",
    "preparse --no-overwrite": "tsx src/tool/preparse.ts --no-overwrite --mc=D:/mc_client/Instances/E2E-E --icons=icon-exports-x64 --modpack=e2ee",
    "sprite:create": "tsx src/tool/sprite.ts",
    "test:picker": "tsx src/tool/test-picker.ts"
  },
  "dependencies": {
    "@committed/trie-search": "^0.1.0",
    "chalk": "^5.6.2",
    "clipboardy": "^5.3.1",
    "culori": "^4.0.2",
    "fast-levenshtein": "^3.0.0",
    "fs-extra": "^11.3.5",
    "ink": "^7.0.5",
    "lodash": "^4.18.1",
    "react": "^19.2.6",
    "sharp": "^0.34.5",
    "skmeans": "^0.11.3",
    "terminal-kit": "^3.1.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/culori": "^4.0.1",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/imagemin": "^9.0.1",
    "@types/imagemin-optipng": "^5.2.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/skmeans": "^0.11.8",
    "@types/terminal-kit": "^2.5.7",
    "@types/yargs": "^17.0.35",
    "boxen": "5.1.2",
    "eslint": "^10.4.1",
    "fast-glob": "^3.3.3",
    "imagemin": "^9.0.1",
    "imagemin-optipng": "^8.0.0",
    "imagemin-pngquant": "^10.0.0",
    "log-update": "^8.0.0",
    "mc-iexporter-iterator": "^1.0.1",
    "mc-jeiexporter": "^1.0.0",
    "skia-canvas": "^3.0.8",
    "terminal-image": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
